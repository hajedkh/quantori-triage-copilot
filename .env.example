LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen2.5:7b

GATEWAY_BASE_URL=https://llm.quantori.ai/v1
GATEWAY_API_KEY=
GATEWAY_MODEL=gpt-4.1

# Optional User Settings
# Backend export tuning
EXPORT_XREF_TIMEOUT=4 # External cross-reference request timeout (seconds)
EXPORT_XREF_BUDGET_SECONDS=18 # Cross-reference latency budget before limiting scope
EXPORT_XREF_TOP_LIMIT=250 # Maximum compounds to query when scope is limited
EXPORT_XREF_PROBE_N=8 # Number of compounds to probe for latency estimation
EXPORT_XREF_WORKERS=16 # Concurrent workers for ChEMBL/PubChem lookup
EXPORT_EMBED_PARALLEL_MIN=4 # Minimum shortlist size before process-pool 3D embedding

# Optional source acquisition tuning
SOURCES_TIMEOUT=6 # Timeout for ChEMBL/PubMed requests (seconds)
SOURCES_KNOWN_ACTIVES_LIMIT=60 # Default known-actives fetch size from ChEMBL activity endpoint
SOURCES_PUBMED_RETMAX=6 # Default PubMed abstract count for dossier generation

# Optional chemistry parallel screening tuning
CHEM_PARALLEL_THRESHOLD=500 # Minimum candidate count before process-pool screening is used
CHEM_BATCH_SIZE=64 # Candidate batch size per process-pool task
CHEM_MAX_WORKERS_CAP=8 # Upper cap for chemistry worker processes

# Optional diversify defaults and bounds
DIVERSIFY_DEFAULT_LAM=0.7 # Default MMR lambda when not provided in request
DIVERSIFY_DEFAULT_CUTOFF=0.35 # Default diversity cutoff when not provided in request
DIVERSIFY_DEFAULT_MAX_GENERATED=200 # Default max generated compounds for diversification
DIVERSIFY_MIN_MAX_GENERATED=1 # Lower clamp for diversification maxGenerated
DIVERSIFY_MAX_MAX_GENERATED=5000 # Upper clamp for diversification maxGenerated

# Optional chat tool payload caps
TOOLS_MAX_EXAMPLES=3 # Maximum example rows returned in compact chat tool summaries
TOOLS_MAX_BATCH=10 # Maximum SMILES accepted in batch descriptor/similarity chat tool calls

# Optional chat runtime tuning
CHAT_MAX_ITERS=2 # Max tool-loop turns for one chat response
CHAT_POLL_INTERVAL_SECONDS=0.05 # Event polling interval while streaming chat tool traces
CHAT_HISTORY_TURNS=6 # Number of prior chat turns included in chat context
CHAT_FORCE_TOOL_FIRST=true # Require a tool call on first chat turn for grounded answers

